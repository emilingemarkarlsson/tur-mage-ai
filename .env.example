PROJECT_NAME=mage_project
ENV=dev
MAGE_VERSION=latest
# MinIO (external S3-compatible storage)
MINIO_ENDPOINT=http://your-minio-host:9000

# S3-style credentials for Mage (use the MinIO values above)
AWS_ACCESS_KEY_ID=your-minio-access-key
AWS_SECRET_ACCESS_KEY=your-minio-secret-key
AWS_REGION=us-east-1
