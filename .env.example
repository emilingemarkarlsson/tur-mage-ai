PROJECT_NAME=mage_project
ENV=dev
MAGE_VERSION=latest
# MinIO (external S3-compatible storage)
MINIO_ENDPOINT=http://your-minio-host:9000

# S3-style credentials for Mage (use the MinIO values above)
AWS_ACCESS_KEY_ID=your-minio-access-key
AWS_SECRET_ACCESS_KEY=your-minio-secret-key
AWS_REGION=us-east-1

# NHL data lake output
DATA_LAKE_PATH=/home/src/mage_project/data_lake
# Källa: nhl-data-reorganized/games/by_date/ (första datum 2010-10-01, senaste 2026).
# Full 2010–2026: sätt 2010-01-01 och ta bort state innan körning: ./scripts/reset_full_games_load.sh
GAMES_START_DATE=2010-01-01
# Valfritt: ladda endast ett år (t.ex. 2010). Sätt med ./scripts/run_games_year.sh 2010. För dagliga uppdateringar: ta bort med ./scripts/run_games_daily.sh
# GAMES_YEAR=2010
# Minnesbesparande: max antal datum per körning (t.ex. 30). Kan sättas i Mage Variables som games_batch_size.
# GAMES_BATCH_SIZE=30
# Var ska Silver + Gold skrivas? local = bara lokalt (läs från S3, bygg Parquet+DuckDB lokalt, migrera senare). s3 = skriv till S3.
DATA_LAKE_SINK=local
# Vid DATA_LAKE_SINK=s3:
# S3_DATA_LAKE_PREFIX=nhl-analytics
# S3_DATA_LAKE_BUCKET=nhlhockey-data
# Streamlit viewer: sökväg till Gold DuckDB. Vid local: mage_project/data_lake/gold/nhl.duckdb (eller absolut path)
# DUCKDB_VIEWER_PATH=
# Refresh: 0 = snabb. Sätt 1 bara om du vill bygga Gold från S3 Silver utan att köra games_pipeline.
# REFRESH_USE_S3_FALLBACK_FOR_GAMES=0

# S3 source selection (hetzner|minio)
S3_SOURCE=hetzner

# Hetzner S3 (source=hetzner)
HETZNER_BUCKET=nhlhockey-data
HETZNER_ENDPOINT=hel1.your-objectstorage.com
HETZNER_REGION=eu-central
HETZNER_ACCESS_KEY=your-hetzner-access-key
HETZNER_SECRET_KEY=your-hetzner-secret-key

# MinIO S3 (source=minio)
MINIO_BUCKET=your-minio-bucket
MINIO_ENDPOINT=http://your-minio-host:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key

# MotherDuck: synka Gold till molnet efter refresh_duckdb_views.
# Skapa token: MotherDuck → Settings → Create token.
# Skapa databasen "nhl" i MotherDuck UI först om den inte finns.
# MOTHERDUCK_TOKEN=your-motherduck-access-token
# MOTHERDUCK_DATABASE_NAME=nhl

# Postgres (metadata DB for Mage)
POSTGRES_DB=mage
POSTGRES_USER=mage
POSTGRES_PASSWORD=mage
MAGE_DATABASE_CONNECTION_URL=postgresql+psycopg2://mage:mage@postgres:5432/mage
